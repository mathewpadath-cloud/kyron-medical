# ─── Backend (copy to backend/.env) ──────────────────────────────────────────

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Vapi.ai Voice AI
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=   # The phone number ID from your Vapi dashboard

# Resend Email API
RESEND_API_KEY=re_...

# Twilio SMS (optional — SMS confirmation is skipped if not set)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1...

# Server
PORT=3001
FRONTEND_URL=http://localhost:5173

# ─── Frontend (copy to frontend/.env) ─────────────────────────────────────────

VITE_BACKEND_URL=http://localhost:3001
VITE_VAPI_PUBLIC_KEY=     # Your Vapi public key (for optional client-side Vapi SDK)
